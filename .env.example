# Copy to .env and fill in. .env is gitignored.

# ── Server-side only (server/ on Vercel), never bundled in the app ──
OPENAI_API_KEY=your-openai-api-key-here
# For server/api/stripe-webhook.js (set these in Vercel, not needed locally):
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...   <- service role, keep secret

# ── App (EXPO_PUBLIC_* is bundled into the APK — public values only) ──
# These have working defaults baked into the code; override if needed.
EXPO_PUBLIC_AI_PROXY_URL=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Premium subscription via Google Play Billing (RevenueCat). The Android
# public SDK key (starts with "goog_"). Get it from RevenueCat → Project →
# API keys. Publishable — safe in the bundle. Without it, Premium stays
# locked and the paywall shows a "coming soon" note.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=   # only when you ship on iOS

# Legacy Stripe path (unused now that billing goes through RevenueCat):
# EXPO_PUBLIC_STRIPE_PAYMENT_LINK=
