# Copy to .env and fill in. .env is gitignored.

# ── Server-side only (server/ on Vercel), never bundled in the app ──
OPENAI_API_KEY=your-openai-api-key-here
# For server/api/stripe-webhook.js (set these in Vercel, not needed locally):
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...   <- service role, keep secret

# ── App (EXPO_PUBLIC_* is bundled into the APK — public values only) ──
# All three have working defaults baked into the code; override if needed.
EXPO_PUBLIC_AI_PROXY_URL=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Stripe Payment Link for the $3.99/mo SOS subscription:
EXPO_PUBLIC_STRIPE_PAYMENT_LINK=
