# Copy to .env and fill in. .env is gitignored.

# Server-side only — used by server/ (Vercel or local-server.mjs), never bundled in the app.
OPENAI_API_KEY=your-openai-api-key-here

# Where the app finds the AI proxy. Leave empty for fully-offline mode.
#   Deployed:          https://your-project.vercel.app
#   Android emulator:  http://10.0.2.2:3001
#   Phone via Expo Go: http://<your-PC-LAN-IP>:3001   (run: node server/local-server.mjs)
EXPO_PUBLIC_AI_PROXY_URL=
